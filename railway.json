{
  "build": {
    "commands": [
      "npm ci",
      "npm run build:client",
      "npm run build:server"
    ]
  },
  "deploy": {
    "startCommand": "npm run start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckCommand": "node .railway/healthcheck.js"
  }
}
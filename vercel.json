{
    "version": 3,
    "builds": [
        {
            "src": "vite.config.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "dist/server/**",
                    "dist/client/**"
                ]
            }
        },
        {
            "src": "dist/server/server-entry.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "dist/server/server-entry.js"
        }
    ],
    "env": {
        "PORT": "5173",
        "ENV": "production"
    }
}